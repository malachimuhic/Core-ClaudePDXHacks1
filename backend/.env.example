# Required: Claude API key from https://console.anthropic.com
ANTHROPIC_API_KEY=your-key-here

# Port for the Express backend (default: 3001)
PORT=3001

# CORS allowed origin — must match the frontend dev server (default: http://localhost:5173)
# In production, set this to your deployed frontend URL (e.g. https://fixitbot.example.com)
FRONTEND_URL=http://localhost:5173
